EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Rotas (opcional — sem chave usa linha direta Porto→Madrid)
EXPO_PUBLIC_OPENROUTE_API_KEY=your-openroute-key
EXPO_PUBLIC_GOOGLE_DIRECTIONS_API_KEY=your-google-directions-key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-android-google-maps-key

# Assistente de voz (opcional — web usa Speech API do browser)
# Nativo: requer development build (npx expo run:android)
